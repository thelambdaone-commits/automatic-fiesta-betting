# API keys that are not part of the Polymarket session
POLYGONSCAN_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Groq AI advisor
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Execution mode
# SIMULATION_MODE=true prevents live orders even when the monitor detects trades.
# LIVE_TRADING=false is an additional kill-switch for live execution.
SIMULATION_MODE=false
LIVE_TRADING=true
# CONFIRM_LIVE_TRADING=true is REQUIRED to enable live trading (safety confirmation)
CONFIRM_LIVE_TRADING=false
